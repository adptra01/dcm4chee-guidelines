            "header": [
              {
                "key": "Content-Type",
                "value": "application/dicom"
              }
            ],
            "body": {
              "mode": "binary",
              "options": {
                "binary": {
                  "filename": ""
                }
              }
            },
            "url": {
              "raw": "https://{{host}}:{{arc_port}}/dcm4chee-arc/aets/{{aet}}/rs/studies",
              "protocol": "https",
