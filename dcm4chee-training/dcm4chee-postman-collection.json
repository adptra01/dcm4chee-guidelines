  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// Auto-get token jika belum ada atau expired",
          "const token = pm.collectionVariables.get('token');",
          "if (!token) {",
          "    const loginUrl = `https://${pm.collectionVariables.get('host')}:${pm.collectionVariables.get('kc_port')}/realms/dcm4che/protocol/openid-connect/token`;",
          "    const loginRequest = {",
          "        url: loginUrl,",
          "        method: 'POST',",
          "        header: { 'Content-Type': 'application/x-www-form-urlencoded' },",
          "        body: {",
          "            mode: 'urlencoded',",
          "            urlencoded: [",
          "                { key: 'client_id', value: 'dcm4chee-arc-ui' },",
          "                { key: 'username', value: pm.collectionVariables.get('username') },",
          "                { key: 'password', value: pm.collectionVariables.get('password') },",
          "                { key: 'grant_type', value: 'password' },",
          "                { key: 'scope', value: 'openid' }",
          "            ]",
          "        },",
          "        rejectUnauthorized: false",
          "    };",
          "",
          "    pm.sendRequest(loginRequest, (err, res) => {",
          "        if (!err) {",
          "            const json = res.json();",
          "            pm.collectionVariables.set('token', json.access_token);",
          "            pm.collectionVariables.set('refresh_token', json.refresh_token);",
          "        }",
          "    });",
          "}"
        ],
        "type": "text/javascript"
      }
    },
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// Auto-set Bearer token ke header Authorization",
          "const token = pm.collectionVariables.get('token');",
          "if (token) {",
          "    pm.request.headers.add({",
          "        key: 'Authorization',",
          "        value: 'Bearer ' + token",
          "    });",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  }
}
