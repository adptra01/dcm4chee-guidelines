              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "https://{{host}}:{{arc_port}}/dcm4chee-arc/aets/{{aet}}/rs/mwlitems",
              "protocol": "https",
              "host": ["{{host}}"],
              "port": "{{arc_port}}",
              "path": ["dcm4chee-arc", "aets", "{{aet}}", "rs", "mwlitems"]
            },
            "description": "Buat MWL item baru."
          },
          "response": []
        }
      ],
