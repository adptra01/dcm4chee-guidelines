          "name": "POST Upload Metadata JSON",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"00100010\": {\"vr\": \"PN\", \"Value\": [\"SUSANTO^BUDI\"]},\n  \"00100020\": {\"vr\": \"LO\", \"Value\": [\"P00123\"]},\n  \"00080060\": {\"vr\": \"CS\", \"Value\": [\"CT\"]},\n  \"00080020\": {\"vr\": \"DA\", \"Value\": [\"20250115\"]},\n  \"00080030\": {\"vr\": \"TM\", \"Value\": [\"120000\"]}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "https://{{host}}:{{arc_port}}/dcm4chee-arc/aets/{{aet}}/rs/studies",
              "protocol": "https",
              "host": ["{{host}}"],
              "port": "{{arc_port}}",
              "path": ["dcm4chee-arc", "aets", "{{aet}}", "rs", "studies"]
            },
            "description": "Upload metadata DICOM dalam format JSON (tanpa pixel data)."
          },
          "response": []
        },
        {
          "name": "POST Upload Multi File",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "multipart/related; type=application/dicom"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file1",
                  "type": "file",
                  "src": "",
                  "disabled": false
                },
                {
                  "key": "file2",
                  "type": "file",
                  "src": "",
