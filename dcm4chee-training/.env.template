# ============================================================
# DCM4CHEE Archive 5.x - Environment Template
# ============================================================
# Copy file ini ke .env dan isi dengan nilai yang sesuai
# Usage: cp .env.template .env
#
# PENTING: JANGAN commit file .env ke version control!
# Tambahkan ke .gitignore
# ============================================================

# ╔═══════════════════════════════════════════════════════════╗
# ║  PASSWORDS - WAJIB DIUBAH untuk production!                ║
# ╚═══════════════════════════════════════════════════════════╝

# OpenLDAP Admin Password
# IMPORTANT: Default LDAP password di slapd-dcm4chee image adalah "secret"
# Lihat: https://github.com/dcm4che/dcm4chee-arc-light/blob/master/dcm4chee-arc-ldap/README.md
# Jika diubah, harus sesuai antara LDAP service dan Archive service.
LDAP_PASSWORD=secret

# PostgreSQL Database
POSTGRES_DB=pacsdb
POSTGRES_USER=pacs
POSTGRES_PASSWORD=gantiPasswordDB_ini_rahasia2025

# Keycloak Admin
KEYCLOAK_PASSWORD=KeycloakPassword_rahasia2025

# OAuth2 Proxy
OAUTH2_CLIENT_ID=dcm4chee-arc-ui
OAUTH2_CLIENT_SECRET=oauth2_secret_client_ini_rahasia2025
OAUTH2_COOKIE_SECRET=$(openssl rand -base64 32)

# Grafana Admin
GRAFANA_PASSWORD=grafanaPassword_rahasia2025

# Backup
BACKUP_RETENTION_DAYS=30

# ╔═══════════════════════════════════════════════════════════╗
# ║  ARCHIVE CONFIGURATION                                   ║
# ╚═══════════════════════════════════════════════════════════╝

# Archive Device Name (AE Title utama)
# CATATAN: Wajib diset sesuai dengan device name yang di-bootstap di LDAP.
# Untuk slapd-dcm4chee image, default device name adalah "dcm4chee-arc".
# Jika diubah, maka LDAP bootstrap juga harus disesuaikan.
# DEVICE_NAME=dcm4chee-arc

# LDAP Domain
LDAP_DOMAIN=dcm4che.org
LDAP_ORG=dcm4che

# ╔═══════════════════════════════════════════════════════════╗
# ║  STORAGE CONFIGURATION                                    ║
# ╚═══════════════════════════════════════════════════════════╝

# Base storage directory (default: /storage/archive)
# ARCHIVE_STORAGE_DIR=/opt/dcm4chee-arc/storage

# External NAS mount point (untuk RS besar)
# ARCHIVE_NEARLINE_STORAGE_DIR=/mnt/nas-archive

# ╔═══════════════════════════════════════════════════════════╗
# ║  PERFORMANCE TUNING                                     ║
# ╚═══════════════════════════════════════════════════════════╝

# JVM Heap Settings (sesuaikan dengan RAM available)
# Level 1 (RS kecil): -Xms1g -Xmx2g
# Level 2 (RS menengah): -Xms2g -Xmx4g
# Level 3 (RS besar): -Xms4g -Xmx8g
# WILDFLY_JAVA_OPTS=-Xms2g -Xmx4g -XX:+UseG1GC