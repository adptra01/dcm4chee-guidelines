              "host": ["{{base}}"],
              "path": ["studies", "{{study_uid}}", "series", "{{series_uid}}", "instances", "{{instance_uid}}", "rendered"],
              "query": [
                { "key": "window", "value": "40,400", "disabled": true },
                { "key": "viewport", "value": "256,256", "disabled": true },
                { "key": "quality", "value": "80", "disabled": true }
              ]
            },
            "description": "Ambil rendered image dalam format PNG.\n\nQuery optional:\n- `window` : Window center dan width (contoh: `40,400` untuk CT)\n- `viewport` : Maksimal ukuran (contoh: `256,256`)\n- `quality` : Kualitas (1-100)"
          }
        },
