            "header": [
              {
                "key": "Accept",
                "value": "image/jpeg"
              }
            ],
            "url": {
              "raw": "{{base}}/studies/{{study_uid}}/series/{{series_uid}}/instances/{{instance_uid}}/rendered",
              "host": ["{{base}}"],
              "path": ["studies", "{{study_uid}}", "series", "{{series_uid}}", "instances", "{{instance_uid}}", "rendered"]
            },
            "description": "Ambil rendered image dalam format JPEG."
          }
        },
        {
          "name": "Retrieve Thumbnail",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "image/png"
              }
            ],
            "url": {
              "raw": "{{base}}/studies/{{study_uid}}/series/{{series_uid}}/instances/{{instance_uid}}/thumbnail",
              "host": ["{{base}}"],
              "path": ["studies", "{{study_uid}}", "series", "{{series_uid}}", "instances", "{{instance_uid}}", "thumbnail"]
            },
            "description": "Ambil thumbnail."
          }
        },
        {
          "name": "Retrieve Study (Multipart DICOM)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "multipart/related; type=\"application/dicom\""
              }
            ],
            "url": {
              "raw": "{{base}}/studies/{{study_uid}}",
              "host": ["{{base}}"],
              "path": ["studies", "{{study_uid}}"]
            },
            "description": "Download semua instance dalam study sebagai multipart DICOM."
          }
        },
        {
          "name": "Retrieve Series (Multipart DICOM)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "multipart/related; type=\"application/dicom\""
              }
            ],
            "url": {
              "raw": "{{base}}/studies/{{study_uid}}/series/{{series_uid}}",
              "host": ["{{base}}"],
              "path": ["studies", "{{study_uid}}", "series", "{{series_uid}}"]
            },
            "description": "Download semua instance dalam series sebagai multipart DICOM."
          }
        }
      ]
    },
    {
      "name": "STOW-RS (Store)",
      "description": "Upload DICOM files ke server",
      "item": [
        {
          "name": "Upload DICOM File",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "multipart/related; type=\"application/dicom\"; boundary=BOUNDARY123"
              },
              {
                "key": "Accept",
                "value": "application/dicom+json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "--BOUNDARY123\r\nContent-Type: application/dicom\r\n\r\n<BINARY DICOM DATA>\r\n--BOUNDARY123--\r\n",
              "options": {
                "raw": {
                  "language": "text"
                }
              }
            },
            "url": {
              "raw": "{{base}}/studies",
              "host": ["{{base}}"],
              "path": ["studies"]
            },
            "description": "Upload file DICOM ke server.\n\n**Cara Upload di Postman:**\n1. Body > pilih \"binary\"\n2. Pilih file .dcm\n3. Header Content-Type:\n   `multipart/related; type=\"application/dicom\"; boundary=DCM4BOUNDARY`\n\nAtau untuk multiple files, gunakan form-data:\n1. Body > pilih \"form-data\"\n2. Key: file (type: File), pilih file .dcm\n3. Tambah key file lagi untuk multiple files"
          }
        }
      ]
    },
    {
      "name": "WADO-URI",
      "description": "WADO-URI endpoint (query string based)",
      "item": [
        {
          "name": "WADO-URI Retrieve Instance",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/dicom"
              }
            ],
            "url": {
              "raw": "https://{{host}}:8443/dcm4chee-arc/aets/DCM4CHEE/wado?requestType=WADO&studyUID={{study_uid}}&seriesUID={{series_uid}}&objectUID={{instance_uid}}&contentType=application/dicom",
              "protocol": "https",
              "host": ["{{host}}"],
              "port": "8443",
              "path": ["dcm4chee-arc", "aets", "DCM4CHEE", "wado"],
              "query": [
                { "key": "requestType", "value": "WADO" },
                { "key": "studyUID", "value": "{{study_uid}}" },
                { "key": "seriesUID", "value": "{{series_uid}}" },
                { "key": "objectUID", "value": "{{instance_uid}}" },
                { "key": "contentType", "value": "application/dicom" }
              ]
            },
            "description": "WADO-URI: download instance via query string.\n\nBase URL: `https://{{host}}:8443/dcm4chee-arc/aets/DCM4CHEE/wado`"
          }
        }
      ]
    },
