    {
      "name": "Export",
      "description": "Export studies ke sistem lain",
      "item": [
        {
          "name": "Export via DICOM (C-STORE)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"DestinationAET\": \"TARGET_AE\",\n  \"DestinationHost\": \"192.168.1.100\",\n  \"DestinationPort\": 11112,\n  \"Priority\": 0\n}"
            },
            "url": {
              "raw": "{{base}}/studies/{{study_uid}}/export/dicom",
              "host": ["{{base}}"],
              "path": ["studies", "{{study_uid}}", "export", "dicom"]
            },
            "description": "Export study ke PACS lain via protokol DICOM."
          }
        },
        {
          "name": "Export via STOW-RS",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
